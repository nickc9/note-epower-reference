---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DifficultyBadge from '../../components/DifficultyBadge.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.title.localeCompare(b.data.title),
);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Guides" description="Maintenance guides for the JDM Nissan Note e-POWER (HE12).">
  <div class="section-heading">
    <h1>Guides</h1>
  </div>
  <p>Step-by-step maintenance guides, with torque specs, fluid capacities, and parts needed.</p>

  <div class="card-grid">
    {guides.map((guide) => (
      <a class="card" href={`${base}guides/${guide.id}/`}>
        <h3>{guide.data.title}</h3>
        <p class="jp">{guide.data.description}</p>
        <div class="meta">
          <DifficultyBadge difficulty={guide.data.difficulty} />
          <span class="oem">{guide.data.time_minutes} min</span>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
